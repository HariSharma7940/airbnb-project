<%- include('../partials/head') %>
</head>
<body class="bg-gray-100">
    <%- include('../partials/nav') %>
    <div class="flex justify-center mt-10">
        <div class="bg-white p-10 rounded shadow-md w-96">
            <h1 class="text-2xl font-bold text-center mb-6">Login with your info</h1>

            <form action="/login" method="POST">
                <input type="text" 
                    name="username" 
                    placeholder="Email/UserName" 
                    class="w-full border border-gray-300 p-3 rounded mb-4 bg-blue-50"
                    required/>
                <input type="password" 
                    name="password" 
                    placeholder="Enter your Password" 
                    class="w-full border border-gray-300 p-3 rounded mb-4 bg-blue-50"
                    required/>
               
                <input type="submit" value="Login"  class="w-full bg-red-500 text-white p-3 rounded cursor-pointer"/>
            </form>
        </div>
    </div>
</body>
</html>