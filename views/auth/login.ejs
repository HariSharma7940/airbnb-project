<%- include('../partials/head') %>
</head>
<body class="bg-gray-100">
    <%- include('../partials/nav') %>
    <div class="flex justify-center mt-10">
        <div class="bg-white p-10 rounded-xl shadow-lg" style="width: 100%; max-width: 440px;">
            <h1 class="text-3xl font-bold text-center mb-1">Welcome Back</h1>
            <p class="text-center text-gray-500 text-sm mb-4">Login to your Airbnb account</p>
            <hr class="mb-6 border-gray-200"/>

            <form action="/login" method="POST">

                <%- include('../partials/errors') %>

                <!-- Email/Username -->
                <div class="mb-4">
                    <label class="text-sm text-gray-600 mb-1 block">Email / Username</label>
                    <div class="flex items-center border border-gray-300 rounded-lg bg-white px-3">
                        <span class="text-gray-400 mr-2">✉️</span>
                        <input type="email" 
                            name="email" 
                            placeholder="Enter your Email" 
                            value="<%= oldInput.email ? oldInput.email: '' %>"
                            class="w-full p-2 outline-none bg-white"
                            required/>
                    </div>
                </div>

                <!-- Password -->
                <div class="mb-6">
                    <label class="text-sm text-gray-600 mb-1 block">Password</label>
                    <div class="flex items-center border border-gray-300 rounded-lg bg-white px-3">
                        <span class="text-gray-400 mr-2">🔒</span>
                        <input type="password" 
                            name="password" 
                            placeholder="Enter Your Password" 
                            class="w-full p-2 outline-none bg-white"
                            required/>
                    </div>
                </div>

                <!-- Submit -->
                <button type="submit" class="w-full bg-red-500 text-white p-3 rounded-lg cursor-pointer hover:bg-red-600 transition duration-300 font-semibold text-lg">
                    Login →
                </button>

                <!-- Signup Link -->
                <p class="text-center text-gray-500 text-sm mt-4">
                    Don't have an account? <a href="/signup" class="text-red-500 font-semibold">Sign Up</a>
                </p>
            </form>
        </div>
    </div>
</body>
</html>