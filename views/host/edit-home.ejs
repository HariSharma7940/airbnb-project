<%- include('../partials/head') %>
</head>
<body class="bg-gray-100">
    <%- include('../partials/nav') %>
    <div class="flex justify-center mt-10">
        <div class="bg-white p-10 rounded shadow-md w-96">
            <h1 class="text-2xl font-bold text-center mb-6"><%=editing? "Edit " : "Register "%>your home on AirBnB.</h1>

            <form action="/host/<%= editing? "edit-home" : "add-home" %>" method="POST">
                <input type="hidden" name="id" value="<%= editing? home?._id : '' %>">
                <input type="text" name="houseName" value="<%= editing? home?.houseName : '' %>" placeholder="Enter House Name here" class="w-full border border-gray-300 p-3 rounded mb-4 bg-blue-50"/>
                <input type="number" name="price" value="<%= editing? home?.price : '' %>" placeholder="Price per Night" class="w-full border border-gray-300 p-3 rounded mb-4 bg-blue-50"/>
                <input type="text" name="location" value="<%= editing? home?.location : '' %>" placeholder="Enter Location" class="w-full border border-gray-300 p-3 rounded mb-4 bg-blue-50"/>
                <input type="text" name="photoUrl" value="<%= editing? home?.photoUrl : '' %>" placeholder="Enter photo URL" class="w-full border border-gray-300 p-3 rounded mb-4 bg-blue-50"/>
                <input type="number" name="rating" value="<%= editing? home?.rating : '' %>" placeholder="Enter Rating (1-5)" class="w-full border border-gray-300 p-3 rounded mb-4 bg-blue-50" min="1" max="5"/>
                <textarea name="description" placeholder="Discribe your Home" class="w-full border border-gray-300 p-3 rounded mb-4 bg-blue-50" rows="3"><%= editing ? home?.description : '' %></textarea>
                <input type="submit" value="<%= editing? "Update Home" : "Add Home" %>" class="w-full bg-red-500 text-white p-3 rounded cursor-pointer"/>
            </form>
        </div>
    </div>
</body>
</html>