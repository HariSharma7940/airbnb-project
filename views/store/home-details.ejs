<%- include('../partials/head') %>
</head>
<body class="bg-gray-100">
    <%- include('../partials/nav') %>

    <div style="max-width: 800px; margin: 2rem auto; padding: 0 1.5rem; font-family: sans-serif;">

        <h1 style="text-align: center; color: #E24B4A; font-size: 1.6rem; font-weight: 600; margin-bottom: 2rem;">
            Details of <%= home.houseName %>
        </h1>

        <div style="background: white; border-radius: 14px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.08); padding: 1.5rem; display: flex; gap: 2rem;">

            <!-- Left: Image -->
            <div style="flex: 1;">
                <img src="<%=home.photo%>" alt="<%= home.houseName %>" style="width: 100%; height: 260px; object-fit: cover; border-radius: 10px;" />
            </div>

            <!-- Right: Info -->
            <div style="flex: 1; display: flex; flex-direction: column; gap: 1rem;">

                <!-- Description -->
                <div style="border-bottom: 1px solid #e5e7eb; padding-bottom: 1rem;">
                    <h3 style="font-size: 16px; font-weight: 700; color: #111827; margin: 0;">Description</h3>
                    <p style="font-size: 14px; color: #6b7280; margin: 0;"><%= home.description %></p>
                </div>

                <!-- Location -->
                <div style="border-bottom: 1px solid #e5e7eb; padding-bottom: 1rem;">
                    <h3 style="font-size: 16px; font-weight: 700; color: #111827; margin: 0 0 4px;">Location</h3>
                    <p style="font-size: 14px; color: #6b7280; margin: 0;"><%= home.location %></p>
                </div>

                <!-- Price -->
                <div style="border-bottom: 1px solid #e5e7eb; padding-bottom: 1rem;">
                    <h3 style="font-size: 16px; font-weight: 700; color: #111827; margin: 0 0 4px;">Price</h3>
                    <p style="font-size: 15px; font-weight: 600; color: #16a34a; margin: 0;">$<%= home.price %> / night</p>
                </div>

                <!-- Rating -->
                <div>
                    <h3 style="font-size: 16px; font-weight: 700; color: #111827; margin: 0 0 4px;">Rating</h3>
                    <p style="font-size: 14px; color: #374151; margin: 0;">⭐ <%= home.rating %> / 5</p>
                </div>

                <div>
                    <%- include('../partials/favourites') %>                    
                </div>

            </div>
        </div>
    </div>

</body>
</html>