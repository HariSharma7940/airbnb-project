<%- include('../partials/head') %>
</head>
<body class="bg-gray-100">
  <%- include('../partials/nav') %>

  <div style="max-width: 1100px; margin: 2rem auto; padding: 0 1.5rem; font-family: sans-serif;">
    
    <h1 style="text-align: center; color: #E24B4A; font-size: 1.6rem; font-weight: 600; margin-bottom: 2rem;">
      Here are our registered homes:
    </h1>

    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 1.5rem;">
      
      <% registeredHomes.forEach(home => { %>
      <div style="background: white; border-radius: 14px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.08); transition: transform 0.2s;" onmouseover="this.style.transform='translateY(-4px)'" onmouseout="this.style.transform='translateY(0)'">
        
        <!-- Image -->
        <div style="width: 100%; height: 180px; overflow: hidden;">
          <img src="<%= home.photoUrl %>" alt="<%= home.houseName %>" style="width: 100%; height: 100%; object-fit: cover;" />
        </div>

        <!-- Info -->
        <div style="padding: 0.85rem 1rem 1rem;">
          <h3 style="margin: 0 0 4px; font-size: 15px; font-weight: 600; color: #111827;"><%= home.houseName %></h3>
          <p style="margin: 0 0 10px; font-size: 13px; color: #6b7280;"><%= home.location %></p>
          <div style="display: flex; align-items: center; justify-content: space-between;">
            <span style="font-size: 15px; font-weight: 600; color: #E24B4A;">RS<%= home.price %> / night</span>
            <span style="font-size: 13px; color: #374151;">⭐ <%= home.rating %></span>
          </div>
        </div>
        <div style="display: flex; gap: 0.5rem; padding: 0 1rem 1rem;">
    <a href="/homes/<%= home._id %>" class="bg-teal-400 text-white p-2 rounded hover:bg-teal-500 transition duration-300" style="flex: 1; text-align: center;">Details</a>
    <%- include('../partials/favourites', {home:home}) %>
</div>

      </div>
      <% }) %>

    </div>
  </div>

</body>
</html>