<nav class="bg-red-500 p-4">
    <ul style="display: flex; align-items: center; width: 100%; gap: 1.5rem;">
        <li>
            <a href="/" style="<%= currentPage === 'index' ? 'background-color: #c0392b;' : '' %>" 
               onmouseover="this.style.backgroundColor='#c0392b'" 
               onmouseout="this.style.backgroundColor='<%= currentPage === 'index' ? '#c0392b' : 'transparent' %>'"
               class="text-white font-semibold transition duration-300 px-3 py-2 rounded-lg flex items-center gap-1">
                🏠 Airbnb
            </a>
        </li>

        <% if (isLoggedIn) { %>
            <% if (user && user.userType === 'guest') { %>
                <li>
                    <a href="/homes" style="<%= currentPage === 'home' ? 'background-color: #c0392b;' : '' %>"
                    onmouseover="this.style.backgroundColor='#c0392b'"
                    onmouseout="this.style.backgroundColor='<%= currentPage === 'home' ? '#c0392b' : 'transparent' %>'"
                    class="text-white font-semibold transition duration-300 px-3 py-2 rounded-lg flex items-center gap-1">
                        🏘 Homes
                    </a>
                </li>

                <li>
                    <a href="/favourites" style="<%= currentPage === 'favourites' ? 'background-color: #c0392b;' : '' %>"
                    onmouseover="this.style.backgroundColor='#c0392b'"
                    onmouseout="this.style.backgroundColor='<%= currentPage === 'favourites' ? '#c0392b' : 'transparent' %>'"
                    class="text-white font-semibold transition duration-300 px-3 py-2 rounded-lg flex items-center gap-1">
                        ❤️ Favourites
                    </a>
                </li>

                <li>
                    <a href="/bookings" style="<%= currentPage === 'bookings' ? 'background-color: #c0392b;' : '' %>"
                    onmouseover="this.style.backgroundColor='#c0392b'"
                    onmouseout="this.style.backgroundColor='<%= currentPage === 'bookings' ? '#c0392b' : 'transparent' %>'"
                    class="text-white font-semibold transition duration-300 px-3 py-2 rounded-lg flex items-center gap-1">
                        📅 Bookings
                    </a>
                </li>
            <% } else { %> 
                <li>
                    <a href="/host/host-home-list" style="<%= currentPage === 'host-homes' ? 'background-color: #c0392b;' : '' %>"
                    onmouseover="this.style.backgroundColor='#c0392b'"
                    onmouseout="this.style.backgroundColor='<%= currentPage === 'host-homes' ? '#c0392b' : 'transparent' %>'"
                    class="text-white font-semibold transition duration-300 px-3 py-2 rounded-lg flex items-center gap-1">
                        🏨 Host Homes
                    </a>
                </li>

                <li>
                    <a href="/host/add-home" style="<%= currentPage === 'addHome' ? 'background-color: #c0392b;' : '' %>"
                    onmouseover="this.style.backgroundColor='#c0392b'"
                    onmouseout="this.style.backgroundColor='<%= currentPage === 'addHome' ? '#c0392b' : 'transparent' %>'"
                    class="text-white font-semibold transition duration-300 px-3 py-2 rounded-lg flex items-center gap-1">
                        ➕ Add Home
                    </a>
                </li>
            <% } %>
        <% } %>

        <% if (!isLoggedIn) { %>
            <li style="margin-left: auto;">
                <a href="/signup" style="<%= currentPage === 'signup' ? 'background-color: #c0392b;' : '' %>"
                   onmouseover="this.style.backgroundColor='#c0392b'"
                   onmouseout="this.style.backgroundColor='<%= currentPage === 'signup' ? '#c0392b' : 'transparent' %>'"
                   class="text-white font-semibold transition duration-300 px-3 py-2 rounded-lg">
                    SignUp
                </a>
            </li>
            <li>
                <a href="/login" style="<%= currentPage === 'login' ? 'background-color: #c0392b;' : '' %>"
                   onmouseover="this.style.backgroundColor='#c0392b'"
                   onmouseout="this.style.backgroundColor='<%= currentPage === 'login' ? '#c0392b' : 'transparent' %>'"
                   class="text-white font-semibold transition duration-300 px-3 py-2 rounded-lg">
                    Login
                </a>
            </li>
        <% } else { %>
            <li style="margin-left: auto;">
                <form action="/logout" method="POST">
                    <button 
                        type="submit"
                        style="border: 2px solid white; border-radius: 8px; padding: 6px 16px;"
                        class="text-white font-semibold transition duration-300 flex items-center gap-1"
                        onmouseover="this.style.backgroundColor='#c0392b'"
                        onmouseout="this.style.backgroundColor='transparent'">
                        🔓 Logout
                    </button>
                </form>
            </li>
        <% } %>

    </ul>
</nav>